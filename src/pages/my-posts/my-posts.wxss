/* 我的发布 */
.container { min-height: 100vh; background: #f0f2f5; padding-bottom: 80px; }

/* 顶栏 */
.top-bar { background: #1a3a5c; padding: 70px 16px 14px; display: flex; align-items: center; justify-content: space-between; }
.back-btn { font-size: 28px; color: #fff; width: 32px; }
.top-bar-title { font-size: 17px; font-weight: 600; color: #fff; }
.top-bar-right { width: 32px; }

.empty { text-align: center; padding: 80px 40px; }
.btn-publish { background: #1a3a5c; color: #fff; border: none; border-radius: 20px; padding: 10px 24px; font-size: 14px; margin-top: 20px; }
.my-list { padding: 12px 16px; }
.my-card { background: #fff; border-radius: 14px; padding: 14px; margin-bottom: 10px; box-shadow: 0 1px 4px rgba(0,0,0,0.06); }
.card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
.supply-type { font-size: 11px; padding: 2px 8px; border-radius: 6px; }
.type-supply { background: #e8fdf5; color: #059669; }
.type-demand { background: #fff3e8; color: #c2410c; }
.card-actions { display: flex; gap: 12px; }
.action-edit, .action-delete { font-size: 13px; }
.action-edit { color: #1a3a5c; }
.action-delete { color: #e85a3a; }
.card-title { font-size: 15px; font-weight: 600; color: #1a1a1a; margin-bottom: 8px; }
.card-tags { display: flex; flex-wrap: wrap; gap: 4px; margin-bottom: 8px; }
.s-tag { background: #f0f2f5; color: #666; font-size: 11px; padding: 2px 7px; border-radius: 6px; }
.card-footer { display: flex; justify-content: space-between; font-size: 12px; color: #999; }
.load-more, .no-more { text-align: center; padding: 16px; font-size: 13px; color: #999; }
.load-more:active { color: #1a3a5c; }