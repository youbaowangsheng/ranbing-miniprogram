<!-- 注册页 -->
<view class="container">
  <view class="header">
    <text class="back" bindtap="goBack">‹</text>
    <text class="title">注册</text>
    <text class="placeholder"></text>
  </view>

  <!-- Step 1: 手机验证 -->
  <view class="step-content {{step!==1?'hidden':''}}">
    <view class="step-title">验证手机号</view>
    <view class="step-hint">未注册的手机号将自动创建账号</view>

    <view class="input-group">
      <view class="input-row">
        <text class="input-label">手机号</text>
        <input class="input-field" type="number" maxlength="11" placeholder="请输入手机号" value="{{phone}}" bindinput="onPhoneInput" />
      </view>
      <view class="input-row">
        <text class="input-label">验证码</text>
        <input class="input-field code-input" type="number" maxlength="6" placeholder="请输入验证码" value="{{smsCode}}" bindinput="onCodeInput" />
        <button class="btn-code" bindtap="sendCode" disabled="{{countdown>0}}">{{countdown>0?countdown+'s':'获取验证码'}}</button>
      </view>
    </view>

    <button class="btn-primary" bindtap="nextStep">下一步</button>
    <view class="protocol-hint">注册即表示同意<a class="protocol-link" bindtap="openProtocol">《用户协议》</a>和<a class="protocol-link" bindtap="openPrivacy">《隐私政策》</a></view>
  </view>

  <!-- Step 2: 设置密码+昵称 -->
  <view class="step-content {{step!==2?'hidden':''}}">
    <view class="step-title">设置账号信息</view>
    <view class="phone-display">
      <text class="phone-label">手机号</text>
      <text class="phone-value">{{phone}}</text>
    </view>

    <view class="input-group">
      <view class="input-row">
        <text class="input-label">昵称</text>
        <input class="input-field" placeholder="请输入昵称（选填）" value="{{nickname}}" bindinput="onNicknameInput" />
      </view>
      <view class="input-row">
        <text class="input-label">密码</text>
        <input class="input-field" password type="text" placeholder="设置密码（6位以上）" value="{{password}}" bindinput="onPasswordInput" />
      </view>
      <view class="input-row">
        <text class="input-label">确认</text>
        <input class="input-field" password type="text" placeholder="再次输入密码" value="{{confirmPwd}}" bindinput="onConfirmPwdInput" />
      </view>
    </view>

    <button class="btn-primary" bindtap="doRegister">完成注册</button>
    <button class="btn-back" bindtap="backToStep1">返回上一步</button>
  </view>

  <view class="error-msg {{errorMsg?'show':'hidden'}}">{{errorMsg}}</view>
</view>