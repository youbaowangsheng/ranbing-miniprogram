/* 活动列表 */
page { background: #f0f2f5; }
.container { min-height: 100vh; background: #f0f2f5; padding-bottom: 100px; }

/* 顶栏：搜索+AI */
.top-bar { background: #1a3a5c; padding: 10px 16px 10px; display: flex; align-items: center; gap: 10px; }
.search-box { flex: 1; background: rgba(255,255,255,0.15); border-radius: 18px; padding: 8px 14px; display: flex; align-items: center; gap: 8px; }
.search-icon { font-size: 14px; opacity: 0.7; }
.search-input { background: none; border: none; font-size: 14px; flex: 1; color: #fff; outline: none; }
.search-input::placeholder { color: rgba(255,255,255,0.5); }
.ai-btn { background: rgba(124,58,237,0.8); color: #fff; font-size: 13px; padding: 8px 14px; border-radius: 14px; flex-shrink: 0; font-weight: 600; }

.loading { text-align: center; padding: 40px; color: #999; }
.tab-bar { display: flex; background: #fff; border-bottom: 1px solid #eee; }
.tab { flex: 1; text-align: center; padding: 12px 0; font-size: 14px; color: #999; }
.tab.active { color: #1a3a5c; font-weight: 600; border-bottom: 2px solid #e86a3a; }

.ai-section { padding: 12px 16px; }
.ai-label { background: linear-gradient(135deg,#7c3aed,#a855f7); color: #fff; font-size: 11px; padding: 2px 8px; border-radius: 8px; display: inline-block; margin-bottom: 8px; }
.ai-card { background: linear-gradient(135deg,#1a3a5c,#2d5a8a); border-radius: 14px; padding: 14px; }
.ai-match-row { display: flex; align-items: center; gap: 8px; margin-bottom: 8px; }
.match-pill { background: rgba(232,106,58,0.2); color: #ff9a7a; font-size: 11px; padding: 2px 8px; border-radius: 8px; }
.match-reason { font-size: 11px; color: rgba(255,255,255,0.6); }
.ai-card-title { font-size: 16px; color: #fff; font-weight: 600; margin-bottom: 6px; }
.ai-card-meta { font-size: 12px; color: rgba(255,255,255,0.7); margin-bottom: 8px; }
.ai-card-footer { display: flex; justify-content: space-between; align-items: center; }
.ai-card-attend { font-size: 12px; color: rgba(255,255,255,0.6); }
.ai-card-tag { font-size: 11px; color: rgba(255,255,255,0.5); margin-left: 8px; }

.category-scroll { display: flex; gap: 8px; padding: 12px 16px; overflow-x: auto; -webkit-overflow-scrolling: touch; }
.cat-chip { padding: 5px 12px; border-radius: 14px; font-size: 12px; white-space: nowrap; background: #f0f0f0; color: #666; flex-shrink: 0; }
.cat-chip.active { background: #1a3a5c; color: #fff; }

.event-list { padding: 0 16px; }
.event-card { background: #fff; border-radius: 14px; padding: 14px; margin-bottom: 10px; display: flex; gap: 12px; box-shadow: 0 1px 4px rgba(0,0,0,0.06); }
.event-thumb { width: 72px; height: 72px; border-radius: 10px; background: linear-gradient(135deg,#e86a3a,#f0a06a); display: flex; align-items: center; justify-content: center; flex-shrink: 0; position: relative; }
.event-label { position: absolute; top: 4px; left: 4px; background: #999; color: #fff; font-size: 9px; padding: 1px 4px; border-radius: 4px; }
.event-info { flex: 1; min-width: 0; }
.event-title { font-size: 15px; font-weight: 600; color: #1a1a1a; margin-bottom: 4px; line-height: 1.3; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.event-meta { font-size: 12px; color: #888; margin-bottom: 2px; }
.event-tags { display: flex; flex-wrap: wrap; gap: 4px; margin-top: 6px; }
.e-tag { background: #f0f2f5; color: #666; font-size: 11px; padding: 2px 6px; border-radius: 6px; }
.load-more, .no-more { text-align: center; padding: 16px; font-size: 13px; color: #999; }
.load-more:active { color: #1a3a5c; }
.empty { text-align: center; padding: 60px 0; }