.page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 80px;
}

.comm-header {
  background: #1a3a5c;
  padding: 20px 16px 16px;
}

.comm-cover {
  width: 100%;
  height: 160px;
  border-radius: 8px;
  overflow: hidden;
  margin-bottom: 12px;
}

.cover-img {
  width: 100%;
  height: 100%;
}

.comm-cover-placeholder {
  width: 100%;
  height: 160px;
  border-radius: 8px;
  background: #2a5a8c;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12px;
}

.comm-icon {
  font-size: 60px;
}

.comm-info {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.comm-name {
  font-size: 18px;
  font-weight: 600;
  color: #ffffff;
}

.comm-meta {
  font-size: 13px;
  color: rgba(255,255,255,0.7);
}

.section {
  background: #ffffff;
  padding: 16px;
  margin-bottom: 8px;
}

.section-title {
  font-size: 14px;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 8px;
}

.comm-desc {
  font-size: 14px;
  color: #666;
  line-height: 1.6;
}

.tab-bar {
  display: flex;
  background: #ffffff;
  border-bottom: 1px solid #eee;
  padding: 0 16px;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 12px 0;
  font-size: 14px;
  color: #666;
  position: relative;
}

.tab-on {
  color: #1a3a5c;
  font-weight: 600;
}

.tab-on::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 32px;
  height: 2px;
  background: #1a3a5c;
  border-radius: 1px;
}

.member-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 12px;
  gap: 12px;
  background: #fff;
}

.member-card {
  width: calc(25% - 9px);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  padding: 8px 0;
}

.member-avatar {
  width: 52px;
  height: 52px;
  border-radius: 50%;
  background: #ddd;
}

.member-name {
  font-size: 12px;
  color: #333;
  max-width: 60px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.member-role {
  font-size: 10px;
  color: #fff;
  background: #1a3a5c;
  padding: 1px 4px;
  border-radius: 4px;
}

.member-admin {
  background: #e67e22;
}

.msg-item {
  background: #fff;
  padding: 12px 16px;
  border-bottom: 1px solid #f0f0f0;
}

.msg-header {
  display: flex;
  align-items: center;
  margin-bottom: 8px;
}

.msg-avatar {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: #ddd;
  margin-right: 8px;
}

.msg-meta {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.msg-name {
  font-size: 14px;
  color: #333;
  font-weight: 500;
}

.msg-time {
  font-size: 12px;
  color: #999;
}

.msg-content {
  font-size: 14px;
  color: #444;
  line-height: 1.6;
}

.post-input {
  background: #fff;
  padding: 16px;
  font-size: 14px;
  min-height: 120px;
  width: 100%;
  box-sizing: border-box;
}

.word-count {
  display: block;
  text-align: right;
  padding: 4px 16px 8px;
  font-size: 12px;
  color: #999;
  background: #fff;
}

.post-btn {
  margin: 0 16px 16px;
  background: #1a3a5c;
  color: #fff;
  font-size: 15px;
  border-radius: 8px;
}

.post-btn.disabled {
  background: #ccc;
}

.load-more, .empty-tip {
  text-align: center;
  padding: 24px;
  color: #999;
  font-size: 14px;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 8px;
  padding: 12px 16px calc(12px + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1px solid #eee;
}

.join-btn {
  flex: 1;
  background: #1a3a5c;
  color: #fff;
  font-size: 15px;
  border-radius: 8px;
}

.joined-btn {
  flex: 1;
  background: #fff;
  color: #1a3a5c;
  border: 1px solid #1a3a5c;
  font-size: 15px;
  border-radius: 8px;
}

.msg-btn {
  width: 100px;
  background: #e67e22;
  color: #fff;
  font-size: 14px;
  border-radius: 8px;
}

.pin-badge {
  font-size: 11px;
  color: #e67e22;
  border: 1px solid #e67e22;
  padding: 1px 6px;
  border-radius: 4px;
}