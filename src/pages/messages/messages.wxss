/* 私信列表 */
page { background: #f0f2f5; }
.container { min-height: 100vh; background: #f0f2f5; padding-bottom: 100px; }

.top-bar { background: #1a3a5c; padding: 10px 16px 10px; display: flex; align-items: center; justify-content: space-between; }
.back-btn { font-size: 24px; color: #fff; padding: 8px 0; min-width: 32px; }
.top-bar-title { font-size: 17px; color: #fff; font-weight: 600; flex: 1; text-align: center; }
.top-bar-right { min-width: 32px; }

.loading { text-align: center; padding: 60px; color: #999; }

.msg-list { padding: 12px 16px; }
.msg-item { background: #fff; border-radius: 12px; padding: 14px; margin-bottom: 10px; display: flex; align-items: center; gap: 12px; box-shadow: 0 1px 4px rgba(0,0,0,0.06); }
.msg-avatar { width: 48px; height: 48px; border-radius: 50%; background: #1a3a5c; color: #fff; display: flex; align-items: center; justify-content: center; font-size: 18px; font-weight: 600; flex-shrink: 0; }
.msg-body { flex: 1; min-width: 0; }
.msg-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 4px; }
.msg-row:last-child { margin-bottom: 0; }
.msg-name { font-size: 15px; font-weight: 600; color: #1a1a1a; flex: 1; }
.msg-time { font-size: 11px; color: #999; flex-shrink: 0; margin-left: 8px; }
.msg-preview { font-size: 13px; color: #888; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 220px; display: block; }
.unread-dot { background: #e86a3a; color: #fff; font-size: 11px; padding: 1px 6px; border-radius: 10px; flex-shrink: 0; margin-left: 6px; }

.empty { text-align: center; padding: 80px 0; }