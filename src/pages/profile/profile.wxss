/* 我的主页 */
.container { min-height: 100vh; background: #f0f2f5; padding-bottom: 100px; }

/* 顶栏 */
.top-bar { background: #1a3a5c; padding: 10px 16px 10px; display: flex; align-items: center; justify-content: center; }
.top-bar-title { font-size: 18px; font-weight: 700; color: #fff; }
.profile-card { background: #fff; margin: 12px 16px; border-radius: 16px; padding: 20px; display: flex; align-items: center; gap: 14px; box-shadow: 0 1px 4px rgba(0,0,0,0.06); }
.profile-avatar { width: 64px; height: 64px; border-radius: 50%; background: #1a3a5c; color: #fff; display: flex; align-items: center; justify-content: center; font-size: 24px; font-weight: 700; flex-shrink: 0; }
.profile-info { flex: 1; min-width: 0; }
.profile-name { font-size: 20px; font-weight: 700; color: #1a1a1a; margin-bottom: 4px; }
.profile-meta { font-size: 13px; color: #888; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.cert-row { display: flex; gap: 6px; margin-top: 6px; flex-wrap: wrap; }
.cert-badge { background: #e8f0fe; color: #1a3a5c; font-size: 11px; padding: 2px 6px; border-radius: 6px; }
.cert-deep { background: linear-gradient(135deg,#7c3aed,#a855f7); color: #fff; }
.edit-arrow { font-size: 24px; color: #ccc; }
.stats-row { background: #fff; margin: 0 16px 16px; border-radius: 14px; padding: 16px; display: flex; align-items: center; box-shadow: 0 1px 4px rgba(0,0,0,0.06); }
.stat-item { flex: 1; text-align: center; }
.stat-num { display: block; font-size: 20px; font-weight: 700; color: #1a3a5c; }
.stat-label { display: block; font-size: 11px; color: #999; margin-top: 2px; }
.stat-divider { width: 1px; height: 30px; background: #eee; }
.menu-section { margin: 0 16px 12px; background: #fff; border-radius: 14px; overflow: hidden; box-shadow: 0 1px 4px rgba(0,0,0,0.06); }
.menu-title { font-size: 12px; color: #999; padding: 10px 16px 6px; }
.menu-item { display: flex; align-items: center; padding: 14px 16px; border-bottom: 1px solid #f5f5f5; }
.menu-item:last-child { border-bottom: none; }
.menu-icon { font-size: 18px; margin-right: 12px; }
.menu-text { flex: 1; font-size: 15px; color: #333; }
.menu-arrow { font-size: 20px; color: #ccc; }
.logout-text { color: #e85a3a; }