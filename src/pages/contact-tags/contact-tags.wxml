<view class="page">
  <view class="top-bar">
    <view class="back-btn" bindtap="goBack">‹</view>
    <text class="top-bar-title">联系人标签</text>
  </view>

  <view class="content">
    <view class="section-title">系统标签</view>
    <view class="tag-list">
      <view wx:for="{{systemTags}}" wx:key="id" class="tag-chip {{item.selected?'selected':''}}" bindtap="toggleTag" data-id="{{item.id}}">
        {{item.name}}
      </view>
    </view>

    <view class="section-title">自定义标签</view>
    <view class="tag-list">
      <view wx:for="{{customTags}}" wx:key="id" class="tag-chip {{item.selected?'selected':''}}" bindtap="toggleTag" data-id="{{item.id}}">
        {{item.name}}
      </view>
      <view class="tag-chip add-tag" bindtap="addTag">+ 新建标签</view>
    </view>

    <view class="save-btn" bindtap="saveTags">保存</view>
  </view>
</view>