.page {
  min-height: 100vh;
  background: #f5f5f5;
}
.top-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 44px;
  background: #1a3a5c;
  display: flex;
  align-items: center;
  z-index: 100;
}
.back-btn {
  color: #fff;
  font-size: 24px;
  padding: 0 12px;
}
.top-bar-title {
  flex: 1;
  text-align: center;
  color: #fff;
  font-size: 17px;
  font-weight: 500;
  padding-right: 36px;
}
.content {
  padding: 60px 16px 20px;
}
.section-title {
  font-size: 13px;
  color: #999;
  margin: 16px 0 10px;
  padding-left: 4px;
}
.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}
.tag-chip {
  background: #fff;
  border: 1px solid #ddd;
  border-radius: 16px;
  padding: 6px 14px;
  font-size: 14px;
  color: #555;
}
.tag-chip.selected {
  background: #1a3a5c;
  border-color: #1a3a5c;
  color: #fff;
}
.tag-chip.add-tag {
  color: #1a3a5c;
  border-style: dashed;
}
.save-btn {
  margin-top: 30px;
  background: #1a3a5c;
  color: #fff;
  text-align: center;
  line-height: 44px;
  border-radius: 8px;
  font-size: 16px;
}