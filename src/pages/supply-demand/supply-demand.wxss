/* 供需广场 */
page { background: #f0f2f5; }
.container { min-height: 100vh; background: #f0f2f5; padding-bottom: 100px; }

/* 顶栏：搜索+AI */
.top-bar { background: #1a3a5c; padding: 10px 16px 10px; display: flex; align-items: center; gap: 10px; }
.search-box { flex: 1; background: rgba(255,255,255,0.15); border-radius: 18px; padding: 8px 14px; display: flex; align-items: center; gap: 8px; }
.search-icon { font-size: 14px; opacity: 0.7; }
.search-input { background: none; border: none; font-size: 14px; flex: 1; color: #fff; outline: none; }
.search-input::placeholder { color: rgba(255,255,255,0.5); }
.ai-btn { background: rgba(124,58,237,0.8); color: #fff; font-size: 13px; padding: 8px 14px; border-radius: 14px; flex-shrink: 0; font-weight: 600; }

.loading { text-align: center; padding: 40px; color: #999; }
.type-tabs { display: flex; background: #fff; border-bottom: 1px solid #eee; }
.type-tab { flex: 1; text-align: center; padding: 12px 0; font-size: 14px; color: #999; }
.type-tab.active { color: #1a3a5c; font-weight: 600; border-bottom: 2px solid #e86a3a; }
.supply-list { padding: 12px 16px; }
.supply-card { background: #fff; border-radius: 14px; padding: 14px; margin-bottom: 10px; box-shadow: 0 1px 4px rgba(0,0,0,0.06); }
.supply-header { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
.supply-avatar { width: 38px; height: 38px; border-radius: 50%; background: #1a3a5c; color: #fff; display: flex; align-items: center; justify-content: center; font-size: 15px; font-weight: 600; flex-shrink: 0; }
.supply-user { flex: 1; }
.supply-name { font-size: 14px; font-weight: 600; color: #1a1a1a; display: block; }
.supply-company { font-size: 12px; color: #888; display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 160px; }
.supply-type { font-size: 11px; padding: 2px 8px; border-radius: 6px; flex-shrink: 0; }
.type-supply { background: #e8fdf5; color: #059669; }
.type-demand { background: #fff3e8; color: #c2410c; }
.supply-title { font-size: 15px; font-weight: 600; color: #1a1a1a; margin-bottom: 6px; line-height: 1.4; }
.supply-content { font-size: 13px; color: #555; margin-bottom: 10px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; line-height: 1.5; }
.supply-tags { display: flex; flex-wrap: wrap; gap: 4px; margin-bottom: 10px; }
.s-tag { background: #f0f2f5; color: #666; font-size: 11px; padding: 2px 7px; border-radius: 6px; }
.supply-footer { display: flex; justify-content: space-between; font-size: 12px; color: #999; }
.supply-stat { }
.load-more, .no-more { text-align: center; padding: 16px; font-size: 13px; color: #999; }
.load-more:active { color: #1a3a5c; }
.empty { text-align: center; padding: 60px 0; }
.publish-fab { position: fixed; right: 20px; bottom: calc(70px + env(safe-area-inset-bottom)); background: #e86a3a; color: #fff; width: 52px; height: 52px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 28px; box-shadow: 0 4px 12px rgba(232,106,58,0.4); }