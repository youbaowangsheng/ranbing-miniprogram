/* 活动详情 */
page { background: #f0f2f5; }
.container { min-height: 100vh; background: #f0f2f5; padding-bottom: 80px; }

.loading { text-align: center; padding: 60px; color: #999; }
.cover { width: 100%; height: 220px; display: flex; align-items: center; justify-content: center; }
.info-card { background: #fff; padding: 16px; margin: 12px 16px; border-radius: 12px; }
.info-title { font-size: 20px; font-weight: 700; color: #1a1a1a; margin-bottom: 12px; line-height: 1.4; }
.info-meta { display: flex; flex-direction: column; gap: 8px; margin-bottom: 12px; }
.meta-item { font-size: 14px; color: #555; }
.info-tags { display: flex; flex-wrap: wrap; gap: 6px; }
.e-tag { background: #f0f2f5; color: #666; font-size: 12px; padding: 2px 8px; border-radius: 8px; }
.info-attendees { margin-top: 10px; }
.attendees-count { font-size: 13px; color: #e86a3a; font-weight: 600; }
.desc-card { background: #fff; padding: 16px; margin: 0 16px 12px; border-radius: 12px; }
.card-title { font-size: 15px; font-weight: 600; color: #1a1a1a; margin-bottom: 10px; }
.card-body { font-size: 14px; color: #555; line-height: 1.7; }
.organizer-card { background: #fff; padding: 16px; margin: 0 16px 80px; border-radius: 12px; }
.organizer-row { display: flex; align-items: center; gap: 10px; }
.org-avatar { width: 44px; height: 44px; border-radius: 50%; background: #1a3a5c; color: #fff; display: flex; align-items: center; justify-content: center; font-size: 16px; font-weight: 600; flex-shrink: 0; }
.org-info { display: flex; flex-direction: column; }
.org-name { font-size: 15px; font-weight: 600; color: #1a1a1a; }
.org-company { font-size: 12px; color: #888; }
.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; background: #fff; border-top: 1px solid #eee; padding: 12px 16px; padding-bottom: calc(12px + env(safe-area-inset-bottom)); display: flex; align-items: center; gap: 12px; z-index: 100; }
.bottom-left { flex: 1; }
.share-hint { font-size: 12px; color: #999; }
.btn-join { background: #e86a3a; color: #fff; border: none; border-radius: 20px; padding: 10px 24px; font-size: 14px; font-weight: 600; }
.btn-joined { background: #1a3a5c; color: #fff; border: none; border-radius: 20px; padding: 10px 24px; font-size: 14px; font-weight: 600; }
.btn-join:active, .btn-joined:active { opacity: 0.85; }