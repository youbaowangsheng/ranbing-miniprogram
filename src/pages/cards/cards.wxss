.page {
  min-height: 100vh;
  background: #f5f5f5;
}
.top-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 44px;
  background: #1a3a5c;
  display: flex;
  align-items: center;
  z-index: 100;
}
.back-btn {
  color: #fff;
  font-size: 24px;
  padding: 0 12px;
}
.top-bar-title {
  flex: 1;
  color: #fff;
  font-size: 17px;
  font-weight: 500;
}
.add-btn {
  color: #fff;
  font-size: 15px;
  padding: 0 16px;
}
.card-list {
  padding: 60px 16px 20px;
}
.loading, .empty {
  text-align: center;
  color: #aaa;
  font-size: 14px;
  padding: 40px 0;
}
.card-item {
  background: #fff;
  border-radius: 12px;
  padding: 18px 20px;
  margin-bottom: 12px;
  position: relative;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
}
.card-item.default {
  border: 2px solid #1a3a5c;
}
.card-default-tag {
  position: absolute;
  top: 12px;
  right: 12px;
  background: #1a3a5c;
  color: #fff;
  font-size: 11px;
  padding: 2px 8px;
  border-radius: 10px;
}
.card-name {
  font-size: 18px;
  font-weight: 600;
  color: #1a3a5c;
  margin-bottom: 4px;
}
.card-company {
  font-size: 14px;
  color: #333;
  margin-bottom: 2px;
}
.card-position {
  font-size: 13px;
  color: #666;
  margin-bottom: 8px;
}
.card-contact {
  display: flex;
  gap: 16px;
  flex-wrap: wrap;
}
.card-contact text {
  font-size: 13px;
  color: #888;
}
.card-actions {
  position: absolute;
  bottom: 12px;
  right: 16px;
  font-size: 12px;
  color: #e55;
}