.top-bar {
  position: fixed;
  top: 0; left: 0; right: 0;
  height: 64px;
  background: #1a3a5c;
  display: flex;
  align-items: center;
  padding: 0 16px;
  z-index: 100;
}
.search-box-wrap {
  flex: 1;
  position: relative;
  height: 38px;
  background: rgba(255,255,255,0.15);
  border-radius: 19px;
  display: flex;
  align-items: center;
  padding: 0 12px;
  margin-right: 10px;
}
.search-box {
  flex: 1;
  color: #fff;
  font-size: 14px;
  height: 100%;
}
.placeholder { color: rgba(255,255,255,0.6); }
.search-icon {
  font-size: 14px;
  opacity: 0.7;
}
.ai-btn {
  font-size: 18px;
  padding: 8px;
}

/* 结果区 */
.container {
  padding-bottom: 20px;
}
.empty-tip {
  text-align: center;
  padding: 60px 0;
  color: #999;
  font-size: 14px;
}
.result-section {
  padding: 0 16px;
  margin-top: 16px;
}
.section-title {
  font-size: 13px;
  color: #999;
  margin-bottom: 10px;
}

/* 用户 */
.user-list { background: #fff; border-radius: 12px; overflow: hidden; }
.user-item {
  display: flex;
  align-items: center;
  padding: 12px 16px;
  border-bottom: 1px solid #f0f0f0;
}
.user-item:last-child { border-bottom: none; }
.avatar {
  width: 44px; height: 44px;
  border-radius: 50%;
  background: #1a3a5c;
  color: #fff;
  font-size: 18px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12px;
  flex-shrink: 0;
}
.user-info { display: flex; flex-direction: column; }
.user-name { font-size: 15px; color: #333; font-weight: 500; }
.user-meta { font-size: 12px; color: #999; margin-top: 3px; }

/* 供给卡片 */
.supply-card {
  background: #fff;
  border-radius: 12px;
  padding: 14px 16px;
  margin-bottom: 10px;
}
.supply-header { display: flex; align-items: center; margin-bottom: 6px; }
.supply-badge {
  font-size: 11px;
  padding: 2px 6px;
  border-radius: 4px;
  margin-right: 8px;
  flex-shrink: 0;
}
.supply-badge.supply { background: #e6f4ea; color: #1a7f37; }
.supply-badge.demand { background: #fff3e0; color: #e65100; }
.supply-title { font-size: 15px; color: #222; font-weight: 500; }
.supply-content {
  display: block;
  font-size: 13px;
  color: #666;
  margin-bottom: 8px;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
.supply-author { font-size: 12px; color: #999; }

/* 活动卡片 */
.activity-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 12px;
  padding: 14px 16px;
  margin-bottom: 10px;
}
.act-badge { font-size: 22px; margin-right: 12px; }
.act-info { display: flex; flex-direction: column; }
.act-title { font-size: 15px; color: #222; font-weight: 500; }
.act-meta { font-size: 12px; color: #999; margin-top: 4px; }

/* 社群卡片 */
.community-card {
  background: #fff;
  border-radius: 12px;
  overflow: hidden;
  margin-bottom: 10px;
}
.comm-banner {
  height: 60px;
  display: flex;
  align-items: center;
  justify-content: center;
}
.comm-icon { font-size: 28px; }
.comm-content { padding: 12px 16px; }
.comm-name { font-size: 15px; color: #222; font-weight: 500; display: block; }
.comm-desc {
  display: block;
  font-size: 13px;
  color: #666;
  margin: 4px 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.comm-meta { font-size: 12px; color: #999; }
