/* 首页瀑布流 */
page { background: #f0f2f5; }
.container { padding-bottom: 100px; }

/* 顶栏：搜索+标题+AI */
.top-bar { background: #1a3a5c; padding: 10px 16px; display: flex; align-items: center; justify-content: space-between; }
.search-icon-btn { font-size: 18px; padding: 4px 8px; color: #fff; }
.top-bar-center { flex: 1; text-align: center; }
.top-bar-title { font-size: 18px; font-weight: 700; color: #fff; }
.top-bar-sub { font-size: 10px; color: rgba(255,255,255,0.6); margin-top: 1px; }
.ai-btn { background: rgba(124,58,237,0.8); color: #fff; font-size: 12px; padding: 6px 12px; border-radius: 14px; flex-shrink: 0; font-weight: 600; }

/* 用户欢迎卡片 */
.user-card { background: #fff; margin: 12px 16px; border-radius: 14px; padding: 14px 16px; display: flex; align-items: center; gap: 12px; box-shadow: 0 1px 4px rgba(0,0,0,0.06); }
.user-info { flex: 1; }
.user-name { font-size: 17px; font-weight: 600; color: #1a1a1a; margin-bottom: 3px; }
.user-meta { font-size: 12px; color: #888; }
.publish-btn { background: linear-gradient(135deg, #e86a3a, #f0a06a); color: #fff; border: none; border-radius: 20px; padding: 6px 16px; font-size: 12px; font-weight: 600; }

/* 加载中 */
.loading { text-align: center; padding: 40px; color: #999; }

/* 瀑布流 */
.waterfall { display: flex; gap: 10px; padding: 0 16px; align-items: flex-start; }
.waterfall-col { flex: 1; min-width: 0; }
.waterfall-item { margin-bottom: 10px; }

/* 供需卡片 */
.supply-card { background: #fff; border-radius: 12px; padding: 14px; box-shadow: 0 1px 4px rgba(0,0,0,0.06); overflow: hidden; }
.sc-header { display: flex; align-items: center; gap: 8px; margin-bottom: 8px; }
.sc-avatar { width: 34px; height: 34px; border-radius: 50%; background: #1a3a5c; color: #fff; display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 600; flex-shrink: 0; }
.sc-user { flex: 1; min-width: 0; }
.sc-name { font-size: 13px; font-weight: 600; color: #1a1a1a; display: block; }
.sc-meta { font-size: 11px; color: #888; display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.sc-type { font-size: 10px; padding: 2px 7px; border-radius: 6px; flex-shrink: 0; }
.type-supply { background: #fff3e0; color: #e86a3a; }
.type-demand { background: #e8fdf5; color: #059669; }
.sc-title { font-size: 14px; font-weight: 600; color: #1a1a1a; margin-bottom: 5px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.sc-content { font-size: 12px; color: #666; line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; margin-bottom: 8px; }
.sc-footer { display: flex; align-items: center; justify-content: space-between; font-size: 11px; color: #aaa; }
.sc-match { color: #e86a3a; font-weight: 600; }

/* 活动卡片 */
.activity-card { background: #fff; border-radius: 12px; overflow: hidden; box-shadow: 0 1px 4px rgba(0,0,0,0.06); position: relative; }
.ac-top { background: linear-gradient(135deg, #e86a3a, #f0a06a); padding: 4px 10px; }
.ac-type-tag { font-size: 11px; color: #fff; }
.ac-thumb { height: 80px; display: flex; align-items: center; justify-content: center; font-size: 32px; background: linear-gradient(135deg, #fdf0e6, #fde8d0); }
.ac-thumb-icon { font-size: 32px; }
.ac-body { padding: 10px 12px; }
.ac-title { font-size: 13px; font-weight: 600; color: #1a1a1a; margin-bottom: 4px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.ac-meta { font-size: 11px; color: #888; margin-bottom: 2px; }

/* 社群卡片 */
.community-card { background: #fff; border-radius: 12px; overflow: hidden; box-shadow: 0 1px 4px rgba(0,0,0,0.06); }
.cc-top { background: linear-gradient(135deg, #1a3a5c, #2d5a8a); padding: 4px 10px; }
.cc-type-tag { font-size: 11px; color: #fff; }
.cc-icon { width: 44px; height: 44px; border-radius: 10px; background: #f0f2f5; display: flex; align-items: center; justify-content: center; font-size: 22px; flex-shrink: 0; margin: 12px 12px 0; }
.cc-body { padding: 8px 12px 12px; }
.cc-name { font-size: 14px; font-weight: 600; color: #1a1a1a; margin-bottom: 3px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.cc-desc { font-size: 12px; color: #888; margin-bottom: 3px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.cc-meta { font-size: 11px; color: #aaa; }

/* 加载更多 */
.load-more { text-align: center; padding: 16px; font-size: 13px; color: #888; }
.no-more { text-align: center; padding: 12px; font-size: 12px; color: #ccc; }

/* 空状态 */
.empty-state { text-align: center; padding: 60px 20px; color: #999; }
.empty-icon { font-size: 48px; display: block; margin-bottom: 16px; }
.empty-text { font-size: 14px; margin-bottom: 20px; }
.publish-btn-empty { background: linear-gradient(135deg, #e86a3a, #f0a06a); color: #fff; border: none; border-radius: 20px; padding: 10px 24px; font-size: 14px; font-weight: 600; }