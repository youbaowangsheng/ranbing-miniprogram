/* 供需详情 */
.container { min-height: 100vh; background: #f0f2f5; padding-bottom: 80px; }
.loading { text-align: center; padding: 60px; color: #999; }
.detail-content { padding: 12px 16px 80px; }
.user-row { background: #fff; border-radius: 14px; padding: 14px; margin-bottom: 12px; display: flex; align-items: center; gap: 10px; }
.user-avatar { width: 48px; height: 48px; border-radius: 50%; background: #1a3a5c; color: #fff; display: flex; align-items: center; justify-content: center; font-size: 18px; font-weight: 600; flex-shrink: 0; }
.user-info { flex: 1; }
.user-name { font-size: 16px; font-weight: 600; color: #1a1a1a; display: block; }
.user-meta { font-size: 12px; color: #888; display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 180px; }
.cert-badge { background: #e8f0fe; color: #1a3a5c; font-size: 11px; padding: 3px 8px; border-radius: 8px; }
.type-tag { display: inline-block; font-size: 12px; padding: 3px 10px; border-radius: 8px; margin-bottom: 10px; }
.type-supply { background: #e8fdf5; color: #059669; }
.type-demand { background: #fff3e8; color: #c2410c; }
.detail-title { background: #fff; border-radius: 14px; padding: 16px; margin-bottom: 12px; font-size: 20px; font-weight: 700; color: #1a1a1a; line-height: 1.4; }
.detail-content-text { background: #fff; border-radius: 14px; padding: 16px; margin-bottom: 12px; font-size: 15px; color: #333; line-height: 1.7; }
.detail-tags { background: #fff; border-radius: 14px; padding: 14px 16px; margin-bottom: 12px; display: flex; flex-wrap: wrap; gap: 6px; }
.s-tag { background: #f0f2f5; color: #666; font-size: 12px; padding: 3px 10px; border-radius: 8px; }
.detail-stats { background: #fff; border-radius: 14px; padding: 14px 16px; margin-bottom: 12px; display: flex; gap: 20px; font-size: 13px; color: #999; }
.action-bar { display: flex; gap: 12px; padding: 0 16px; }
.btn-connect { flex: 1; background: #e86a3a; color: #fff; border: none; border-radius: 24px; padding: 12px 0; font-size: 15px; font-weight: 600; }
.btn-share { flex: 1; background: #fff; color: #1a3a5c; border: 1px solid #1a3a5c; border-radius: 24px; padding: 12px 0; font-size: 15px; }
.btn-connect:active { opacity: 0.85; }