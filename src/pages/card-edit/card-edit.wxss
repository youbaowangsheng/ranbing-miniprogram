.page {
  min-height: 100vh;
  background: #f5f5f5;
}
.top-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 44px;
  background: #1a3a5c;
  display: flex;
  align-items: center;
  z-index: 100;
}
.back-btn {
  color: #fff;
  font-size: 24px;
  padding: 0 12px;
}
.top-bar-title {
  flex: 1;
  text-align: center;
  color: #fff;
  font-size: 17px;
  font-weight: 500;
  padding-right: 36px;
}
.form {
  padding: 60px 16px 30px;
}
.field {
  background: #fff;
  padding: 12px 16px;
  margin-bottom: 1px;
  display: flex;
  align-items: center;
}
.label {
  width: 60px;
  font-size: 14px;
  color: #555;
  flex-shrink: 0;
}
.input {
  flex: 1;
  font-size: 14px;
  color: #222;
  height: 36px;
}
.textarea {
  flex: 1;
  font-size: 14px;
  color: #222;
  height: 80px;
  resize: none;
}
.default-row {
  margin-top: 10px;
  border-radius: 8px;
  overflow: hidden;
}
.default-row .label {
  width: auto;
  flex: 1;
}
.submit-btn {
  margin-top: 30px;
  background: #1a3a5c;
  color: #fff;
  text-align: center;
  line-height: 48px;
  border-radius: 8px;
  font-size: 16px;
}