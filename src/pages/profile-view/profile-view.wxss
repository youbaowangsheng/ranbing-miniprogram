/* pages/profile-view/profile-view.wxss */
page { background: #f5f5f5; }
.container { min-height: 100vh; }

.top-bar {
  background: #1a3a5c;
  padding: 12px 16px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
}
.back-btn { color: #fff; font-size: 28px; padding: 4px; }
.top-bar-title { color: #fff; font-size: 16px; font-weight: 600; }

.loading { text-align: center; padding: 80px; color: #888; }

.profile-content { padding-top: 60px; }

.profile-header {
  background: #fff;
  padding: 24px 18px;
  display: flex;
  gap: 16px;
  align-items: flex-start;
  border-bottom: 1px solid #f0f0f0;
}
.avatar {
  width: 64px; height: 64px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26px;
  font-weight: 700;
  color: #fff;
  flex-shrink: 0;
}
.header-info { flex: 1; }
.name-row { display: flex; align-items: center; gap: 6px; margin-bottom: 6px; }
.name { font-size: 20px; font-weight: 700; color: #1a1a1a; }
.cert-badge { font-size: 14px; color: #059669; }
.meta { font-size: 13px; color: #888; margin-bottom: 3px; }

.tags-row {
  background: #fff;
  padding: 12px 18px;
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  border-bottom: 1px solid #f0f0f0;
}
.tag { background: #f0f4ff; color: #1a3a5c; font-size: 12px; padding: 3px 10px; border-radius: 12px; }

.bio-section { background: #fff; padding: 14px 18px; }
.bio-text { font-size: 14px; color: #444; line-height: 1.6; }

.action-row {
  display: flex;
  gap: 12px;
  padding: 16px 18px;
}
.action-btn {
  flex: 1;
  padding: 12px;
  border-radius: 10px;
  text-align: center;
  font-size: 15px;
  font-weight: 600;
  background: #f0f0f0;
  color: #666;
}
.action-btn.primary {
  background: linear-gradient(135deg, #1a3a5c, #2d5a8a);
  color: #fff;
}

.empty-state { text-align: center; padding: 80px 20px; }
.empty-icon { font-size: 48px; display: block; margin-bottom: 12px; }
.empty-text { font-size: 14px; color: #999; }